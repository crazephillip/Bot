{
  "crons": [
    { "path": "/api/cron/fetch-options", "schedule": "0 13 * * *" },
    { "path": "/api/cron/fetch-nba",     "schedule": "0 12 * * *" }
  ],
  "rewrites": [
    { "source": "/",       "destination": "/options.html" },
    { "source": "/options","destination": "/options.html" },
    { "source": "/nba",    "destination": "/nba.html" }
  ]
}
